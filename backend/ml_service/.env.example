# ─── Flask ML Service ─────────────────────────────────────
PORT=8000
FLASK_ENV=development

# ─── Shared Internal Secret ───────────────────────────────
# MUST match ML_SERVICE_API_KEY in backend/server/.env
ML_SERVICE_API_KEY=must_match_the_value_in_node_server_env

# ─── Model Version ────────────────────────────────────────
MODEL_VERSION=1.0.0

# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
MONGODB_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/agrifert

# ─── JWT ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_random_hex
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_another_64_byte_random_hex
JWT_REFRESH_EXPIRES_IN=30d

# ─── ML Microservice (internal, Node ↔ Flask only) ────────
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_API_KEY=replace_with_strong_internal_secret

# ─── Weather API ──────────────────────────────────────────
# Free key from https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key
WEATHER_API_BASE=https://api.openweathermap.org/data/2.5

# ─── Gemini AI (Soil Health Tips) ─────────────────────────
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Rate Limits ──────────────────────────────────────────
LOGIN_LIMIT_MAX=5
REGISTER_LIMIT_MAX=3
ANALYZE_LIMIT_MAX=20

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# ─── Admin ────────────────────────────────────────────────
# Secret phrase required when registering the first admin account
ADMIN_SECRET_KEY=any_secret_phrase_you_choose
